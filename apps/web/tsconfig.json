{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts"
  ],
  "exclude": ["node_modules", ".svelte-kit", "build"]
}
