# ──────────────────────────────────────────────
# POLIS Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Required — all modes
DATABASE_URL=postgres://polis:polis@localhost:5432/polis
POLIS_SESSION_SECRET=change-me-to-a-32-byte-random-hex-string
POLIS_AI_KEY=your-ai-provider-api-key

# Required — multi-tenant only
# STRIPE_SECRET=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# PLATFORM_DOMAIN=polis.app

# Optional — standalone SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=password

# Optional — standalone LDAP
# LDAP_URL=ldap://ldap.example.com:389

# Optional — all modes
POLIS_LOG_LEVEL=debug
POLIS_LOG_FORMAT=pretty
POLIS_MAX_UPLOAD_MB=10
POLIS_RATE_LIMIT_ENABLED=true

# Optional — S3-compatible storage
# S3_BUCKET=polis-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=key
# S3_SECRET_KEY=secret
# S3_ENDPOINT=http://localhost:9000

# Redis
REDIS_URL=redis://localhost:6379
